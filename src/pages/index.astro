---
import Layout from '../layouts/Layout.astro';
import AboutSection from '../components/AboutSection.astro';
import SkillsSection from '../components/SkillsSection.astro';
import FieldWork from '../components/FieldWork.astro';
import ContactSection from '../components/ContactSection.astro';
import LanyardCard from '../components/LanyardCard';
import { hero } from '../data/site';
---

<Layout>
  <main>

    <!-- Opening / Hero -->
    <section
      id="opening"
      class="min-h-screen flex flex-col justify-center px-8 md:px-20 lg:px-32 relative overflow-hidden"
    >
      <!-- Text content — leaves room on the right for the absolute lanyard column -->
      <div class="max-w-[1200px] mx-auto w-full pt-24 pb-32 lg:pr-[420px] xl:pr-[480px]">

        <p class="hero-label text-muted text-xs tracking-[0.2em] uppercase mb-10">
          {hero.label}
        </p>

        <h1 class="hero-name font-display font-light text-text leading-[0.88] tracking-[-0.03em] mb-14"
            style="font-size: clamp(4.5rem, 10vw, 9rem);">
          {hero.name}
        </h1>

        <p class="hero-bio text-muted text-lg md:text-xl leading-[1.7] max-w-lg font-body font-light">
          {hero.bio}
        </p>

      </div>

      <!-- Lanyard column: absolute, full hero height, right side — rope appears to hang from top of screen -->
      <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[420px] xl:w-[480px]">
        <LanyardCard client:load />
      </div>

      <!-- Scroll indicator -->
      <div class="hero-scroll absolute bottom-10 left-8 md:left-20 lg:left-32 flex items-end gap-4">
        <div class="w-px h-14 bg-muted/30"></div>
        <span class="text-muted/60 text-[0.65rem] tracking-[0.25em] uppercase pb-1">Scroll</span>
      </div>

    </section>

    <!-- Origin / About -->
    <AboutSection />

    <!-- Signal / Skills -->
    <SkillsSection />

    <!-- Field work -->
    <FieldWork />

    <!-- Reach / Contact -->
    <ContactSection />

  </main>
</Layout>

<script>
  import { animateHero, animateAbout, animateSkills, animateContact, initAccordions } from '../utils/animations';
  animateHero();
  animateAbout();
  animateSkills();
  animateContact();
  initAccordions();
</script>
