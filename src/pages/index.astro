---
import Layout from '../layouts/Layout.astro';
import AboutSection from '../components/AboutSection.astro';
import { hero } from '../data/site';
---

<Layout>
  <main>

    <!-- Opening / Hero -->
    <section
      id="opening"
      class="min-h-screen flex flex-col justify-center px-8 md:px-20 lg:px-32 relative"
    >
      <div class="max-w-[1200px] mx-auto w-full pt-24 pb-32">

        <p class="hero-label text-muted text-xs tracking-[0.2em] uppercase mb-10">
          {hero.label}
        </p>

        <h1 class="hero-name font-display font-light text-text leading-[0.88] tracking-[-0.03em] mb-14"
            style="font-size: clamp(4.5rem, 13vw, 11rem);">
          {hero.name}
        </h1>

        <p class="hero-bio text-muted text-lg md:text-xl leading-[1.7] max-w-lg font-body font-light">
          {hero.bio}
        </p>

      </div>

      <!-- Scroll indicator -->
      <div class="hero-scroll absolute bottom-10 left-8 md:left-20 lg:left-32 flex items-end gap-4">
        <div class="w-px h-14 bg-muted/30"></div>
        <span class="text-muted/60 text-[0.65rem] tracking-[0.25em] uppercase pb-1">Scroll</span>
      </div>

    </section>

    <!-- Origin / About -->
    <AboutSection />

  </main>

  <!--
    Flower field — inline SVG, no background fill, blends into cream page.
    Animation classes (.sw .swl .swBg .swBgL .swFt .swFtL) defined in global.css
    so they are never processed/scoped by Vite. <g> wrappers ensure correct
    transform-origin (bottom center of each plant's bounding box).
  -->
  <svg
    viewBox="0 0 1440 220"
    width="100%"
    xmlns="http://www.w3.org/2000/svg"
    preserveAspectRatio="xMidYMax slice"
    style="height:210px;display:block;pointer-events:none;margin-top:0"
    aria-hidden="true"
  >
    <defs>
      <!-- Individual grass blades — base at (0,0), grow upward -->
      <path id="g1" d="M0,0C-3,-42 2,-78 0,-102C1,-78 4,-42 2,0Z"  fill="#2A4A3E"/>
      <path id="g2" d="M0,0C-2,-30 2,-56 1,-76C2,-56 4,-30 2,0Z"   fill="#3D6B5A"/>
      <path id="g3" d="M0,0C-1,-18 1,-34 0,-46C1,-34 3,-18 2,0Z"   fill="#6B9E86"/>
      <path id="g4" d="M0,0C-1,-13 1,-24 0,-33C0,-24 2,-13 1,0Z"   fill="#5A8A74"/>
      <path id="g5" d="M0,0C-1,-10 0,-19 0,-26C0,-19 1,-10 1,0Z"   fill="#7AAE94" opacity="0.75"/>
      <path id="g6" d="M0,0C0,-7  0,-14 0,-20C0,-14 1,-7  1,0Z"    fill="#8BB89C" opacity="0.60"/>

      <!-- Background patch groups — 6 blades per patch, ~30px wide, 3 variants -->
      <g id="pA">
        <use href="#g5" transform="translate(0,0)"/>
        <use href="#g6" transform="translate(5,0)"/>
        <use href="#g3" transform="translate(11,0)"/>
        <use href="#g5" transform="translate(17,0)"/>
        <use href="#g4" transform="translate(22,0)"/>
        <use href="#g6" transform="translate(28,0)"/>
      </g>
      <g id="pB">
        <use href="#g6" transform="translate(3,0)"/>
        <use href="#g4" transform="translate(8,0)"/>
        <use href="#g5" transform="translate(14,0)"/>
        <use href="#g3" transform="translate(19,0)"/>
        <use href="#g6" transform="translate(25,0)"/>
        <use href="#g4" transform="translate(30,0)"/>
      </g>
      <g id="pC">
        <use href="#g4" transform="translate(1,0)"/>
        <use href="#g5" transform="translate(7,0)"/>
        <use href="#g6" transform="translate(13,0)"/>
        <use href="#g4" transform="translate(20,0)"/>
        <use href="#g5" transform="translate(26,0)"/>
        <use href="#g3" transform="translate(31,0)"/>
      </g>

      <!-- Daisy — stem + 8 petals + yellow centre -->
      <g id="dsy">
        <line x1="1" y1="0" x2="1" y2="-40" stroke="#3D6B5A" stroke-width="1.5"/>
        <g transform="translate(1,-40)">
          <ellipse cx="0" cy="-9" rx="2.5" ry="6" fill="#F5F0E8"/>
          <ellipse cx="0" cy="-9" rx="2.5" ry="6" fill="#F5F0E8" transform="rotate(45)"/>
          <ellipse cx="0" cy="-9" rx="2.5" ry="6" fill="#F5F0E8" transform="rotate(90)"/>
          <ellipse cx="0" cy="-9" rx="2.5" ry="6" fill="#F5F0E8" transform="rotate(135)"/>
          <ellipse cx="0" cy="-9" rx="2.5" ry="6" fill="#F5F0E8" transform="rotate(180)"/>
          <ellipse cx="0" cy="-9" rx="2.5" ry="6" fill="#F5F0E8" transform="rotate(225)"/>
          <ellipse cx="0" cy="-9" rx="2.5" ry="6" fill="#F5F0E8" transform="rotate(270)"/>
          <ellipse cx="0" cy="-9" rx="2.5" ry="6" fill="#F5F0E8" transform="rotate(315)"/>
          <circle cx="0" cy="0" r="4.5" fill="#E8C547"/>
        </g>
      </g>

      <!-- Orange bloom — stem + 5 petals + amber centre -->
      <g id="blo">
        <line x1="1" y1="0" x2="1" y2="-30" stroke="#3D6B5A" stroke-width="1.2"/>
        <g transform="translate(1,-30)">
          <ellipse cx="0" cy="-6" rx="2" ry="5" fill="#C94A2A"/>
          <ellipse cx="0" cy="-6" rx="2" ry="5" fill="#C94A2A" transform="rotate(72)"/>
          <ellipse cx="0" cy="-6" rx="2" ry="5" fill="#C94A2A" transform="rotate(144)"/>
          <ellipse cx="0" cy="-6" rx="2" ry="5" fill="#C94A2A" transform="rotate(216)"/>
          <ellipse cx="0" cy="-6" rx="2" ry="5" fill="#C94A2A" transform="rotate(288)"/>
          <circle cx="0" cy="0" r="2.5" fill="#E8A020"/>
        </g>
      </g>

      <!-- Yellow bloom — stem + 5 petals + pale centre -->
      <g id="bly">
        <line x1="1" y1="0" x2="1" y2="-26" stroke="#3D6B5A" stroke-width="1.2"/>
        <g transform="translate(1,-26)">
          <ellipse cx="0" cy="-5.5" rx="1.8" ry="4.5" fill="#E8C547"/>
          <ellipse cx="0" cy="-5.5" rx="1.8" ry="4.5" fill="#E8C547" transform="rotate(72)"/>
          <ellipse cx="0" cy="-5.5" rx="1.8" ry="4.5" fill="#E8C547" transform="rotate(144)"/>
          <ellipse cx="0" cy="-5.5" rx="1.8" ry="4.5" fill="#E8C547" transform="rotate(216)"/>
          <ellipse cx="0" cy="-5.5" rx="1.8" ry="4.5" fill="#E8C547" transform="rotate(288)"/>
          <circle cx="0" cy="0" r="2" fill="#F0D965"/>
        </g>
      </g>
    </defs>

    <!-- ── Background patch layer (48 patches × 6 blades = 288 tiny blades) ── -->
    <!-- y=218: slightly recessed to read as distance -->
    <g class="swBg"  style="animation-delay:0s"    transform="translate(0,218)"><use href="#pA"/></g>
    <g class="swBgL" style="animation-delay:0.2s"  transform="translate(30,218)"><use href="#pB"/></g>
    <g class="swBg"  style="animation-delay:0.4s"  transform="translate(60,218)"><use href="#pC"/></g>
    <g class="swBgL" style="animation-delay:0.6s"  transform="translate(90,218)"><use href="#pA"/></g>
    <g class="swBg"  style="animation-delay:0.8s"  transform="translate(120,218)"><use href="#pB"/></g>
    <g class="swBgL" style="animation-delay:1.0s"  transform="translate(150,218)"><use href="#pC"/></g>
    <g class="swBg"  style="animation-delay:1.2s"  transform="translate(180,218)"><use href="#pA"/></g>
    <g class="swBgL" style="animation-delay:1.4s"  transform="translate(210,218)"><use href="#pB"/></g>
    <g class="swBg"  style="animation-delay:1.6s"  transform="translate(240,218)"><use href="#pC"/></g>
    <g class="swBgL" style="animation-delay:1.8s"  transform="translate(270,218)"><use href="#pA"/></g>
    <g class="swBg"  style="animation-delay:2.0s"  transform="translate(300,218)"><use href="#pB"/></g>
    <g class="swBgL" style="animation-delay:2.2s"  transform="translate(330,218)"><use href="#pC"/></g>
    <g class="swBg"  style="animation-delay:0s"    transform="translate(360,218)"><use href="#pA"/></g>
    <g class="swBgL" style="animation-delay:0.2s"  transform="translate(390,218)"><use href="#pB"/></g>
    <g class="swBg"  style="animation-delay:0.4s"  transform="translate(420,218)"><use href="#pC"/></g>
    <g class="swBgL" style="animation-delay:0.6s"  transform="translate(450,218)"><use href="#pA"/></g>
    <g class="swBg"  style="animation-delay:0.8s"  transform="translate(480,218)"><use href="#pB"/></g>
    <g class="swBgL" style="animation-delay:1.0s"  transform="translate(510,218)"><use href="#pC"/></g>
    <g class="swBg"  style="animation-delay:1.2s"  transform="translate(540,218)"><use href="#pA"/></g>
    <g class="swBgL" style="animation-delay:1.4s"  transform="translate(570,218)"><use href="#pB"/></g>
    <g class="swBg"  style="animation-delay:1.6s"  transform="translate(600,218)"><use href="#pC"/></g>
    <g class="swBgL" style="animation-delay:1.8s"  transform="translate(630,218)"><use href="#pA"/></g>
    <g class="swBg"  style="animation-delay:2.0s"  transform="translate(660,218)"><use href="#pB"/></g>
    <g class="swBgL" style="animation-delay:2.2s"  transform="translate(690,218)"><use href="#pC"/></g>
    <g class="swBg"  style="animation-delay:0s"    transform="translate(720,218)"><use href="#pA"/></g>
    <g class="swBgL" style="animation-delay:0.2s"  transform="translate(750,218)"><use href="#pB"/></g>
    <g class="swBg"  style="animation-delay:0.4s"  transform="translate(780,218)"><use href="#pC"/></g>
    <g class="swBgL" style="animation-delay:0.6s"  transform="translate(810,218)"><use href="#pA"/></g>
    <g class="swBg"  style="animation-delay:0.8s"  transform="translate(840,218)"><use href="#pB"/></g>
    <g class="swBgL" style="animation-delay:1.0s"  transform="translate(870,218)"><use href="#pC"/></g>
    <g class="swBg"  style="animation-delay:1.2s"  transform="translate(900,218)"><use href="#pA"/></g>
    <g class="swBgL" style="animation-delay:1.4s"  transform="translate(930,218)"><use href="#pB"/></g>
    <g class="swBg"  style="animation-delay:1.6s"  transform="translate(960,218)"><use href="#pC"/></g>
    <g class="swBgL" style="animation-delay:1.8s"  transform="translate(990,218)"><use href="#pA"/></g>
    <g class="swBg"  style="animation-delay:2.0s"  transform="translate(1020,218)"><use href="#pB"/></g>
    <g class="swBgL" style="animation-delay:2.2s"  transform="translate(1050,218)"><use href="#pC"/></g>
    <g class="swBg"  style="animation-delay:0s"    transform="translate(1080,218)"><use href="#pA"/></g>
    <g class="swBgL" style="animation-delay:0.2s"  transform="translate(1110,218)"><use href="#pB"/></g>
    <g class="swBg"  style="animation-delay:0.4s"  transform="translate(1140,218)"><use href="#pC"/></g>
    <g class="swBgL" style="animation-delay:0.6s"  transform="translate(1170,218)"><use href="#pA"/></g>
    <g class="swBg"  style="animation-delay:0.8s"  transform="translate(1200,218)"><use href="#pB"/></g>
    <g class="swBgL" style="animation-delay:1.0s"  transform="translate(1230,218)"><use href="#pC"/></g>
    <g class="swBg"  style="animation-delay:1.2s"  transform="translate(1260,218)"><use href="#pA"/></g>
    <g class="swBgL" style="animation-delay:1.4s"  transform="translate(1290,218)"><use href="#pB"/></g>
    <g class="swBg"  style="animation-delay:1.6s"  transform="translate(1320,218)"><use href="#pC"/></g>
    <g class="swBgL" style="animation-delay:1.8s"  transform="translate(1350,218)"><use href="#pA"/></g>
    <g class="swBg"  style="animation-delay:2.0s"  transform="translate(1380,218)"><use href="#pB"/></g>
    <g class="swBgL" style="animation-delay:2.2s"  transform="translate(1410,218)"><use href="#pC"/></g>

    <!-- ── Foreground blades (25 tall dark blades, y=222 = closest layer) ── -->
    <g class="swFt"  style="animation-delay:0.1s"  transform="translate(5,222)"><use href="#g2"/></g>
    <g class="swFtL" style="animation-delay:0.5s"  transform="translate(63,222)"><use href="#g1"/></g>
    <g class="swFt"  style="animation-delay:0.9s"  transform="translate(121,222)"><use href="#g2"/></g>
    <g class="swFtL" style="animation-delay:1.3s"  transform="translate(179,222)"><use href="#g1"/></g>
    <g class="swFt"  style="animation-delay:1.7s"  transform="translate(237,222)"><use href="#g2"/></g>
    <g class="swFtL" style="animation-delay:0.3s"  transform="translate(295,222)"><use href="#g1"/></g>
    <g class="swFt"  style="animation-delay:0.7s"  transform="translate(353,222)"><use href="#g2"/></g>
    <g class="swFtL" style="animation-delay:1.1s"  transform="translate(411,222)"><use href="#g1"/></g>
    <g class="swFt"  style="animation-delay:1.5s"  transform="translate(469,222)"><use href="#g2"/></g>
    <g class="swFtL" style="animation-delay:1.9s"  transform="translate(527,222)"><use href="#g1"/></g>
    <g class="swFt"  style="animation-delay:0.2s"  transform="translate(585,222)"><use href="#g2"/></g>
    <g class="swFtL" style="animation-delay:0.6s"  transform="translate(643,222)"><use href="#g1"/></g>
    <g class="swFt"  style="animation-delay:1.0s"  transform="translate(701,222)"><use href="#g2"/></g>
    <g class="swFtL" style="animation-delay:1.4s"  transform="translate(759,222)"><use href="#g1"/></g>
    <g class="swFt"  style="animation-delay:1.8s"  transform="translate(817,222)"><use href="#g2"/></g>
    <g class="swFtL" style="animation-delay:0.4s"  transform="translate(875,222)"><use href="#g1"/></g>
    <g class="swFt"  style="animation-delay:0.8s"  transform="translate(933,222)"><use href="#g2"/></g>
    <g class="swFtL" style="animation-delay:1.2s"  transform="translate(991,222)"><use href="#g1"/></g>
    <g class="swFt"  style="animation-delay:1.6s"  transform="translate(1049,222)"><use href="#g2"/></g>
    <g class="swFtL" style="animation-delay:2.0s"  transform="translate(1107,222)"><use href="#g1"/></g>
    <g class="swFt"  style="animation-delay:0.1s"  transform="translate(1165,222)"><use href="#g2"/></g>
    <g class="swFtL" style="animation-delay:0.5s"  transform="translate(1223,222)"><use href="#g1"/></g>
    <g class="swFt"  style="animation-delay:0.9s"  transform="translate(1281,222)"><use href="#g2"/></g>
    <g class="swFtL" style="animation-delay:1.3s"  transform="translate(1339,222)"><use href="#g1"/></g>
    <g class="swFt"  style="animation-delay:1.7s"  transform="translate(1397,222)"><use href="#g2"/></g>

    <!-- ── Daisies (13, y=220) ── -->
    <g class="sw"  style="animation-delay:0.2s"  transform="translate(52,220)"><use href="#dsy"/></g>
    <g class="swl" style="animation-delay:0.7s"  transform="translate(162,220)"><use href="#dsy"/></g>
    <g class="sw"  style="animation-delay:1.3s"  transform="translate(272,220)"><use href="#dsy"/></g>
    <g class="swl" style="animation-delay:0.5s"  transform="translate(382,220)"><use href="#dsy"/></g>
    <g class="sw"  style="animation-delay:1.0s"  transform="translate(492,220)"><use href="#dsy"/></g>
    <g class="swl" style="animation-delay:1.6s"  transform="translate(602,220)"><use href="#dsy"/></g>
    <g class="sw"  style="animation-delay:0.3s"  transform="translate(712,220)"><use href="#dsy"/></g>
    <g class="swl" style="animation-delay:0.9s"  transform="translate(822,220)"><use href="#dsy"/></g>
    <g class="sw"  style="animation-delay:1.5s"  transform="translate(932,220)"><use href="#dsy"/></g>
    <g class="swl" style="animation-delay:0.4s"  transform="translate(1042,220)"><use href="#dsy"/></g>
    <g class="sw"  style="animation-delay:1.1s"  transform="translate(1152,220)"><use href="#dsy"/></g>
    <g class="swl" style="animation-delay:1.8s"  transform="translate(1262,220)"><use href="#dsy"/></g>
    <g class="sw"  style="animation-delay:0.6s"  transform="translate(1372,220)"><use href="#dsy"/></g>

    <!-- ── Orange blooms (11, y=220) ── -->
    <g class="sw"  style="animation-delay:0.4s"  transform="translate(22,220)"><use href="#blo"/></g>
    <g class="swl" style="animation-delay:1.0s"  transform="translate(152,220)"><use href="#blo"/></g>
    <g class="sw"  style="animation-delay:1.7s"  transform="translate(282,220)"><use href="#blo"/></g>
    <g class="swl" style="animation-delay:0.3s"  transform="translate(412,220)"><use href="#blo"/></g>
    <g class="sw"  style="animation-delay:0.9s"  transform="translate(542,220)"><use href="#blo"/></g>
    <g class="swl" style="animation-delay:1.5s"  transform="translate(672,220)"><use href="#blo"/></g>
    <g class="sw"  style="animation-delay:0.2s"  transform="translate(802,220)"><use href="#blo"/></g>
    <g class="swl" style="animation-delay:0.8s"  transform="translate(932,220)"><use href="#blo"/></g>
    <g class="sw"  style="animation-delay:1.4s"  transform="translate(1062,220)"><use href="#blo"/></g>
    <g class="swl" style="animation-delay:0.6s"  transform="translate(1192,220)"><use href="#blo"/></g>
    <g class="sw"  style="animation-delay:1.2s"  transform="translate(1322,220)"><use href="#blo"/></g>

    <!-- ── Yellow blooms (13, y=220) ── -->
    <g class="swl" style="animation-delay:0.6s"  transform="translate(95,220)"><use href="#bly"/></g>
    <g class="sw"  style="animation-delay:1.2s"  transform="translate(205,220)"><use href="#bly"/></g>
    <g class="swl" style="animation-delay:0.4s"  transform="translate(315,220)"><use href="#bly"/></g>
    <g class="sw"  style="animation-delay:1.0s"  transform="translate(425,220)"><use href="#bly"/></g>
    <g class="swl" style="animation-delay:1.7s"  transform="translate(535,220)"><use href="#bly"/></g>
    <g class="sw"  style="animation-delay:0.3s"  transform="translate(645,220)"><use href="#bly"/></g>
    <g class="swl" style="animation-delay:0.9s"  transform="translate(755,220)"><use href="#bly"/></g>
    <g class="sw"  style="animation-delay:1.5s"  transform="translate(865,220)"><use href="#bly"/></g>
    <g class="swl" style="animation-delay:0.2s"  transform="translate(975,220)"><use href="#bly"/></g>
    <g class="sw"  style="animation-delay:0.8s"  transform="translate(1085,220)"><use href="#bly"/></g>
    <g class="swl" style="animation-delay:1.4s"  transform="translate(1195,220)"><use href="#bly"/></g>
    <g class="sw"  style="animation-delay:0.5s"  transform="translate(1305,220)"><use href="#bly"/></g>
    <g class="swl" style="animation-delay:1.1s"  transform="translate(1415,220)"><use href="#bly"/></g>
  </svg>

</Layout>

<script>
  import { animateHero, animateAbout, initAccordions } from '../utils/animations';
  animateHero();
  animateAbout();
  initAccordions();
</script>
