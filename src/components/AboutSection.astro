---
import { about } from '../data/site';
---

<section id="origin" class="px-8 md:px-20 lg:px-32 pt-24 pb-0">
  <div class="max-w-[1200px] mx-auto">

    <!-- Section entry: thin rule + label anchors the section visually -->
    <div class="mb-16 md:mb-20">
      <hr class="border-t border-muted/20" />
      <div class="flex justify-between items-baseline mt-4">
        <p class="about-label text-muted text-xs tracking-[0.2em] uppercase">Origin</p>
        <span class="text-muted/25 text-xs tracking-[0.2em] font-body">01</span>
      </div>
    </div>

    <!-- 12-column grid: narrative left, stat anchored right -->
    <div class="grid grid-cols-12 gap-x-6 lg:gap-x-10 items-start">

      <!-- Left column — narrative, education, personal note -->
      <div class="col-span-12 md:col-span-7">

        <div class="about-narrative space-y-6 mb-10">
          {about.narrative.map((para) => (
            <p class="text-text text-xl md:text-2xl leading-[1.72] font-body font-light">
              {para}
            </p>
          ))}
        </div>

        <!-- Education: thin rule separates credential from argument -->
        <div class="border-t border-muted/15 pt-8 mb-8">
          <p class="about-education text-muted text-sm leading-relaxed font-body tracking-[0.01em]">
            {about.education}
          </p>
        </div>

        <!-- Human note: one sentence, not a list -->
        <p class="about-human text-muted/80 text-base leading-[1.75] font-body font-light">
          {about.human}
        </p>

      </div>

      <!-- Right column — Samsung stat, anchored to top of left text -->
      <div class="about-stat col-span-12 md:col-span-4 md:col-start-9 mt-10 md:mt-0 self-start">
        <span
          class="about-stat-number font-display font-light text-text leading-none tracking-[-0.05em] block"
          style="font-size: clamp(5rem, 10vw, 8rem);"
        >
          0
        </span>
        <div class="mt-3 space-y-1">
          <p class="text-muted text-sm font-body">{about.samsung.context}</p>
          <p class="text-muted/50 text-xs tracking-[0.18em] uppercase font-body">{about.samsung.program}</p>
        </div>
      </div>

    </div>

  </div>

  <!-- Green Bengaluru: full-bleed closing beat — breaks out of section padding -->
  <div class="about-volunteer -mx-8 md:-mx-20 lg:-mx-32 mt-20 md:mt-28 bg-surface px-8 md:px-20 lg:px-32 py-16 md:py-20">
    <div class="max-w-[1200px] mx-auto">

      <!-- Large italic serif as the primary statement -->
      <p class="font-display italic font-light text-accent-alt leading-[1.45] max-w-3xl"
         style="font-size: clamp(1.4rem, 3vw, 2.1rem);">
        &ldquo;{about.volunteering.detail}&rdquo;
      </p>

      <!-- Attribution as a quiet footer to the statement -->
      <p class="text-muted/50 text-xs tracking-[0.22em] uppercase font-body mt-8">
        {about.volunteering.event}&ensp;&mdash;&ensp;{about.volunteering.org},&ensp;{about.volunteering.date}
      </p>

    </div>
  </div>

</section>
