---
import { about } from '../data/site';
import SamsungCard from './SamsungCard';
---

<section id="origin" class="px-8 md:px-20 lg:px-32 pt-24 pb-0">
  <div class="max-w-[1200px] mx-auto">

    <!-- Section entry: thin rule + label -->
    <div class="mb-16 md:mb-20">
      <hr class="border-t border-muted/20" />
      <div class="flex justify-between items-baseline mt-4">
        <p class="about-label text-muted text-xs tracking-[0.2em] uppercase">Origin</p>
        <span class="text-muted/25 text-xs tracking-[0.2em] font-body">01</span>
      </div>
    </div>

    <!-- Grid: all content left (7 cols) + sticky Samsung card right (4 cols) -->
    <div class="grid grid-cols-12 gap-x-6 lg:gap-x-10">

      <!-- LEFT — narrative, education, human note, mobile Samsung, CardSwap, Sketchbook -->
      <div class="col-span-12 md:col-span-7">

        <div class="about-narrative space-y-6 mb-10">
          {about.narrative.map((para) => (
            <p class="text-text text-xl md:text-2xl leading-[1.72] font-body font-light">{para}</p>
          ))}
        </div>

        <!-- Education: thin rule separates credential from argument -->
        <div class="border-t border-muted/15 pt-8 mb-8">
          <p class="about-education text-muted text-sm leading-relaxed font-body tracking-[0.01em]">
            {about.education}
          </p>
        </div>

        <!-- Human note -->
        <p class="about-human text-muted/80 text-base leading-[1.75] font-body font-light">
          {about.human}
        </p>

        <!-- Mobile: Samsung inline (hidden on md+) -->
        <div class="md:hidden mt-8 mb-2 border-t border-muted/15 pt-6">
          <SamsungCard
            client:load
            variant="inline"
            context={about.samsung.context}
            stat={about.samsung.stat}
            subtext={about.samsung.subtext}
            courses={about.samsung.courses}
          />
        </div>


      </div>

      <!-- RIGHT — sticky Samsung credential card (hidden on mobile) -->
      <div class="about-samsung hidden md:block col-span-4 col-start-9">
        <div class="sticky top-8">
          <SamsungCard
            client:load
            context={about.samsung.context}
            stat={about.samsung.stat}
            subtext={about.samsung.subtext}
            courses={about.samsung.courses}
          />
        </div>
      </div>

    </div>

  </div>

  <!-- Volunteering — full-bleed, first-person, with accordion detail -->
  <div class="about-volunteer -mx-8 md:-mx-20 lg:-mx-32 mt-20 md:mt-28 bg-surface px-8 md:px-20 lg:px-32 py-16 md:py-20">
    <div class="max-w-[1200px] mx-auto">

      <p class="font-display italic font-light text-accent-alt leading-[1.45] max-w-3xl"
         style="font-size: clamp(1.4rem, 3vw, 2.1rem);">
        {about.volunteering.statement}
      </p>

      <button
        class="mt-6 flex items-center gap-2 group"
        aria-expanded="false"
        data-accordion-trigger="volunteering"
      >
        <span class="text-muted/50 text-[0.65rem] tracking-[0.2em] uppercase font-body
                     group-hover:text-muted/80 transition-colors duration-200">
          Details
        </span>
        <svg
          class="volunteering-chevron text-muted/30 group-hover:text-muted/60 transition-all duration-300"
          width="12" height="12" viewBox="0 0 12 12" fill="none"
        >
          <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="overflow-hidden" style="height: 0;" data-accordion-content="volunteering">
        <div class="pt-5 space-y-3">
          {[
            ['Organised by', about.volunteering.organizer],
            ['Date',         about.volunteering.date],
            ['Goal',         about.volunteering.goal],
            ['Record',       about.volunteering.record],
            ['Role',         about.volunteering.role],
          ].map(([label, value]) => (
            <p class="text-muted/60 text-xs font-body leading-relaxed">
              <span class="text-muted/35 tracking-[0.15em] uppercase mr-3">{label}</span>
              {value}
            </p>
          ))}
        </div>
      </div>

    </div>
  </div>

</section>
